# Slatewell demo env (chunk 4b)
#
# Portal JWKS federation. Slatewell verifies Portal-issued JWTs locally
# using the public key set published at PORTAL_JWKS_URL. See
# portal-shell/docs/PORTAL_GATE_CONTRACT.md for the full contract.
PORTAL_JWKS_URL=https://portal.projectnexuscode.org/.well-known/jwks.json
PORTAL_EXPECTED_ISSUER=https://portal.projectnexuscode.org
PORTAL_EXPECTED_AUD=slatewell

# Stripe (deposit holds via manual capture). Live keys live in Vercel.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Optional: override the SQLite path. Defaults to ./data/slatewell.db.
# SLATEWELL_DB_PATH=
